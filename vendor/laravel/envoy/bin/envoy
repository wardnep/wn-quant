#!/usr/bin/env php
<?php

if (file_exists(__DIR__.'/../vendor/autoload.php')) {
    require __DIR__.'/../vendor/autoload.php';
} else {
    require __DIR__.'/../../../autoload.php';
}

$app = new Symfony\Component\Console\Application('Laravel Envoy', '2.12.2');

$addCommandMethodName = method_exists($app, 'addCommand') ? 'addCommand' : 'add';

$app->{$addCommandMethodName}(new Laravel\Envoy\Console\RunCommand);
$app->{$addCommandMethodName}(new Laravel\Envoy\Console\SshCommand);
$app->{$addCommandMethodName}(new Laravel\Envoy\Console\InitCommand);
$app->{$addCommandMethodName}(new Laravel\Envoy\Console\TasksCommand);

$app->run();
